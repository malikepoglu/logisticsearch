{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "logisticsearch_taxonomy_language_schema_v1",
  "title": "LogisticSearch Taxonomy Language Schema v1",
  "description": "Canonical per-language taxonomy source schema. PostgreSQL is runtime; JSON is source of truth.",
  "type": "object",
  "required": [
    "schema_version",
    "language",
    "source_policy",
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "taxonomy_language_v1"
    },
    "language": {
      "type": "object",
      "required": [
        "order",
        "code",
        "english_name",
        "native_name"
      ],
      "additionalProperties": false,
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 25
        },
        "code": {
          "type": "string",
          "pattern": "^[a-z]{2}$"
        },
        "english_name": {
          "type": "string",
          "minLength": 1
        },
        "native_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_policy": {
      "type": "object",
      "required": [
        "canonical_source",
        "runtime_database",
        "ranking_policy",
        "mutation_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "canonical_source": {
          "const": "json"
        },
        "runtime_database": {
          "const": "postgresql"
        },
        "ranking_policy": {
          "const": "taxonomy_ids_only_no_scores_here"
        },
        "mutation_policy": {
          "const": "json_to_scratch_audit_then_live_swap"
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_code",
          "title",
          "terms"
        ],
        "additionalProperties": false,
        "properties": {
          "node_code": {
            "type": "string",
            "pattern": "^[0-9]+(\\.[0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "terms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "term_id",
                "term",
                "role",
                "is_searchable"
              ],
              "additionalProperties": false,
              "properties": {
                "term_id": {
                  "type": "string",
                  "pattern": "^[a-z]{2}_[0-9]+(_[0-9]+)*_(primary|synonym|alias|abbreviation|legacy)_[0-9]{3}$"
                },
                "term": {
                  "type": "string",
                  "minLength": 1
                },
                "role": {
                  "type": "string",
                  "enum": [
                    "primary",
                    "synonym",
                    "alias",
                    "abbreviation",
                    "legacy"
                  ]
                },
                "is_searchable": {
                  "type": "boolean"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
