#!/usr/bin/env bash
set -Eeuo pipefail
if [ "${EUID:-$(id -u)}" -ne 0 ]; then
  exec sudo /usr/local/bin/wifion "$@"
fi
WIFI_DISABLED="/etc/netplan/60-wlan0.yaml.disabled"
WIFI_ENABLED="/etc/netplan/60-wlan0.yaml"
if [ -f "$WIFI_ENABLED" ]; then
  echo "Wi-Fi config already enabled."
else
  if [ ! -f "$WIFI_DISABLED" ]; then
    echo "ERROR: $WIFI_DISABLED not found" >&2
    exit 1
  fi
  mv "$WIFI_DISABLED" "$WIFI_ENABLED"
fi
netplan generate
netplan apply
echo "WIFI_ON_APPLY_DONE"
ip -br a | grep -E "^(eth0|wlan0)" || true
ip route || true
