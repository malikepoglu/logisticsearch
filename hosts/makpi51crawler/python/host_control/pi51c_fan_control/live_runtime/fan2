#!/usr/bin/env bash
set -Eeuo pipefail
MODE="/etc/pi51c-fans/fan2.mode"

show() {
  echo "fan2: $(cat "$MODE" 2>/dev/null || echo missing)"
}

[ $# -eq 1 ] || { echo "usage: fan2 auto|0-255"; show; exit 2; }

if [ "$1" = "auto" ]; then
  echo auto | sudo tee "$MODE" >/dev/null
  echo "fan2=auto"
  exit 0
fi

if [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -ge 0 ] && [ "$1" -le 255 ]; then
  echo "manual $1" | sudo tee "$MODE" >/dev/null
  echo "fan2=manual value=$1"
  exit 0
fi

echo "invalid input ignored: $1"
show
exit 0
